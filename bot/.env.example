# MetaTrader5 Connection
MT5_LOGIN=12345678
MT5_PASSWORD=your_password
MT5_SERVER=ICMarketsSC-Demo
# MT5_PATH=/path/to/terminal64.exe  # Optional, full path to MT5 terminal

# Trading Configuration
TRADING_SYMBOL=EURUSD
FAST_MA_PERIOD=20
SLOW_MA_PERIOD=50
RSI_PERIOD=14
RSI_OVERBOUGHT=70
RSI_OVERSOLD=30

# Risk Management
STOP_LOSS_PIPS=50
TAKE_PROFIT_PIPS=100
MAX_DAILY_LOSS_PERCENT=2.0
MAX_POSITION_SIZE=0.1
MAX_TRADES_PER_DAY=5
TRADE_TIMEOUT_MINUTES=60

# Trading Hours (UTC)
TRADING_START_HOUR=0
TRADING_END_HOUR=23

# Execution
CHECK_INTERVAL_SECONDS=60

# Logging
LOG_DIR=./logs
LOG_LEVEL=INFO
MAX_LOG_SIZE_MB=10
BACKUP_COUNT=5

# Database
DB_PATH=./trading_bot.db

# Monitoring
ENABLE_API=true
API_HOST=0.0.0.0
API_PORT=8000
HEALTH_CHECK_INTERVAL=300
